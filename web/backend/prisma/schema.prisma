generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}

model User {
  id                String           @id @default(uuid())
  firstName         String
  middleName        String?
  lastName          String
  email             String           @unique
  phone             String?
  password          String?
  role              UserRole         @default(PATIENT)
  dateOfBirth       DateTime
  gender            Gender
  maritalStatus     MaritalStatus?   @default(SINGLE)
  subscriptionState SubStatus        @default(UNSUBSCRIBED)
  organizationId    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  stripeCustomerId  String?          @unique
  doctor            DoctorProfile?
  recvMessages      Message[]        @relation("MessagesRecv")
  sentMessages      Message[]        @relation("MessagesSent")
  patient           PatientProfile?
  pharmacy          PharmacyProfile?
  subscriptions     Subscription[]
  supportAgent      SupportAgent?
  sentReplies       SupportReply[]
  raisedTickets     SupportTicket[]  @relation("raisedBy")
  organization      Organization?    @relation(fields: [organizationId], references: [id])
  notifications     Notification[]
  transactions      Transaction[]

  @@index([organizationId])
  @@map("User")
  @@schema("public")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  ownerId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  @@map("Organization")
  @@schema("public")
}

model SupportAgent {
  id              Int             @id @default(autoincrement())
  userId          String          @unique
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTickets SupportTicket[]

  @@map("SupportAgent")
  @@schema("public")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  actorId   String
  actorRole String
  action    String
  entity    String?
  entityId  String?
  metadata  String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("ActivityLog")
  @@schema("public")
}

model DoctorProfile {
  id                    String              @id @default(uuid())
  userId                String              @unique
  specialization        String
  customProfession      String?
  qualifications        String
  licenseNumber         String              @unique
  hospitalAffiliation   String?
  yearsOfExperience     Int?
  consultationFee       Float
  availability          String?
  timezone              String              @default("UTC")
  bio                   String?
  languages             String?
  emergencyContact      String?
  emergencyContactName  String?
  emergencyContactEmail String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  appointments          Appointment[]       @relation("DoctorAppointments")
  encounters            ClinicalEncounter[]
  doctorPatients        DoctorPatient[]     @relation("DoctorPatient_Doctor")
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules             DoctorSchedule[]    @relation("DoctorSchedules")
  labOrders             LabOrder[]
  prescriptions         Prescription[]
  referralsSent         Referral[]          @relation("Referrer")
  referralsRecv         Referral[]          @relation("Referee")
  consultations         VideoConsultation[] @relation("DoctorConsultations")

  @@map("DoctorProfile")
  @@schema("public")
}

model PharmacyProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  displayName        String?
  licenseNumber      String?
  phone              String?
  address            String?
  city               String?
  state              String?
  country            String?
  postalCode         String?
  latitude           Float?
  longitude          Float?
  openingHours       String?
  services           String?
  timezone           String             @default("UTC")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescriptions      Prescription[]
  selectedByPatients SelectedPharmacy[]
  medicines          Medicine[]
  medicineOrders     MedicineOrder[]

  @@map("PharmacyProfile")
  @@schema("public")
}

model PatientProfile {
  id                    String              @id @default(uuid())
  userId                String              @unique
  bloodGroup            BloodGroup
  height                Float?
  heightUnit            String?             @default("cm")
  weight                Float?
  weightUnit            String?             @default("kg")
  allergies             String?
  medications           String?
  medicalHistory        String?
  address               String?
  medicalRecordNumber   String?             @unique
  insuranceProvider     String?
  insuranceMemberId     String?
  emergencyContact      String?
  emergencyContactName  String?
  emergencyContactEmail String?
  riskLevel             String?
  chronicConditions     String?
  disabilityStatus      String?
  timezone              String              @default("UTC")
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  appointments          Appointment[]       @relation("PatientAppointments")
  encounters            ClinicalEncounter[]
  doctorLinks           DoctorPatient[]     @relation("DoctorPatient_Patient")
  labOrders             LabOrder[]
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescriptions         Prescription[]
  referrals             Referral[]
  selectedPharmacies    SelectedPharmacy[]
  consultations         VideoConsultation[] @relation("PatientConsultations")
  medicineOrders        MedicineOrder[]

  @@map("PatientProfile")
  @@schema("public")
}

model Appointment {
  id              String             @id @default(uuid())
  doctorId        String
  patientId       String
  appointmentDate DateTime
  startTime       DateTime?
  endTime         DateTime?
  reason          String?
  status          AppointmentStatus  @default(PENDING)
  chiefComplaint  String?
  intakeNotes     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  roomName        String?
  callStatus      String             @default("idle")
  paymentStatus   String?            @default("UNPAID")
  paymentId       String?            @unique
  doctor          DoctorProfile      @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)
  patient         PatientProfile     @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  encounter       ClinicalEncounter?
  transactions    Transaction[]

  @@index([doctorId])
  @@index([patientId])
  @@index([appointmentDate])
  @@map("Appointment")
  @@schema("public")
}

model DoctorSchedule {
  id            String        @id @default(uuid())
  doctorId      String
  dayOfWeek     Int
  startTime     String
  endTime       String
  slotDuration  Int           @default(15)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  doctor        DoctorProfile @relation("DoctorSchedules", fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([dayOfWeek])
  @@map("DoctorSchedule")
  @@schema("public")
}

model SupportTicket {
  id        Int            @id @default(autoincrement())
  ticketNo  String         @unique @default(uuid())
  userId    String
  agentId   Int?
  subject   String
  body      String
  status    TicketStatus   @default(OPEN)
  priority  Priority       @default(MEDIUM)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  replies   SupportReply[]
  agent     SupportAgent?  @relation(fields: [agentId], references: [id])
  user      User           @relation("raisedBy", fields: [userId], references: [id], onDelete: Cascade)

  @@map("SupportTicket")
  @@schema("public")
}

model SupportReply {
  id        Int           @id @default(autoincrement())
  ticketId  Int
  userId    String
  message   String
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("SupportReply")
  @@schema("public")
}

model Prescription {
  id             String                     @id @default(cuid())
  doctorId       String
  patientId      String
  medication     String
  dosage         String
  frequency      String
  duration       String
  notes          String?
  isControlled   Boolean                    @default(false)
  deaNumber      String?
  refills        Int                        @default(0)
  drugAlerts     String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  pharmacyId     String?
  dispatchStatus PrescriptionDispatchStatus @default(NONE)
  dispatchedAt   DateTime?
  encounterId    String?
  doctor         DoctorProfile              @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  encounter      ClinicalEncounter?         @relation(fields: [encounterId], references: [id])
  patient        PatientProfile             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  pharmacy       PharmacyProfile?           @relation(fields: [pharmacyId], references: [id])
  medicineOrders MedicineOrder[]

  @@index([doctorId])
  @@index([patientId])
  @@index([pharmacyId])
  @@map("Prescription")
  @@schema("public")
}

model ClinicalEncounter {
  id            String          @id @default(uuid())
  appointmentId String          @unique
  doctorId      String
  patientId     String
  subjective    String?
  objective     String?
  assessment    String?
  plan          String?
  systolic      Int?
  diastolic     Int?
  pulse         Int?
  temperature   Float?
  weight        Float?
  oxygenSat     Int?
  status        EncounterStatus @default(DRAFT)
  signedAt      DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  appointment   Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor        DoctorProfile   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient       PatientProfile  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  labOrders     LabOrder[]
  prescriptions Prescription[]
  referrals     Referral[]

  @@map("ClinicalEncounter")
  @@schema("public")
}

model LabOrder {
  id          String             @id @default(uuid())
  doctorId    String
  patientId   String
  encounterId String?
  testName    String
  status      LabStatus          @default(ORDERED)
  results     String?
  orderedAt   DateTime           @default(now())
  completedAt DateTime?
  doctor      DoctorProfile      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  encounter   ClinicalEncounter? @relation(fields: [encounterId], references: [id])
  patient     PatientProfile     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("LabOrder")
  @@schema("public")
}

model Referral {
  id             String             @id @default(uuid())
  doctorId       String
  patientId      String
  encounterId    String?
  targetDoctorId String?
  specialistName String?
  type           ReferralType
  reason         String
  status         String             @default("PENDING")
  doctor         DoctorProfile      @relation("Referrer", fields: [doctorId], references: [id], onDelete: Cascade)
  encounter      ClinicalEncounter? @relation(fields: [encounterId], references: [id])
  patient        PatientProfile     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  referee        DoctorProfile?     @relation("Referee", fields: [targetDoctorId], references: [id])

  @@map("Referral")
  @@schema("public")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String?   // Unified conversation ID for grouping
  senderId       String?
  receiverId     String?
  content        String
  createdAt      DateTime  @default(now())
  readAt         DateTime?
  receiver       User?     @relation("MessagesRecv", fields: [receiverId], references: [id], onDelete: Cascade)
  sender         User?     @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("Message")
  @@schema("public")
}


model VideoConsultation {
  id              String             @id @default(uuid())
  doctorId        String
  patientId       String
  title           String?
  notes           String?
  scheduledAt     DateTime
  durationMins    Int?
  status          ConsultationStatus @default(SCHEDULED)
  roomName        String?
  meetingUrl      String?
  actualStartTime DateTime?
  actualEndTime   DateTime?
  recordingUrl    String?
  failureReason   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  doctor          DoctorProfile      @relation("DoctorConsultations", fields: [doctorId], references: [id], onDelete: Cascade)
  patient         PatientProfile     @relation("PatientConsultations", fields: [patientId], references: [id], onDelete: Cascade)
  videoSession    VideoSession?

  @@index([doctorId])
  @@index([patientId])
  @@map("VideoConsultation")
  @@schema("public")
}

model SubscriptionSetting {
  id                 Int      @id @default(1)
  doctorMonthlyUsd   Float?
  doctorYearlyUsd    Float?
  patientMonthlyUsd  Float?
  patientYearlyUsd   Float?
  pharmacyMonthlyUsd Float?
  pharmacyYearlyUsd  Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("SubscriptionSetting")
  @@schema("public")
}

model Subscription {
  id                   String        @id @default(uuid())
  userId               String
  plan                 Plan
  status               SubStatus     @default(PENDING)
  provider             String?
  reference            String?       @unique
  amount               Int?
  currency             String?
  startDate            DateTime?
  endDate              DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?     @db.Timestamp(6)
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions         Transaction[]

  @@index([userId])
  @@index([status])
  @@index([plan])
  @@map("Subscription")
  @@schema("public")
}

model DoctorPatient {
  id        String         @id @default(uuid())
  doctorId  String
  patientId String
  createdAt DateTime       @default(now())
  doctor    DoctorProfile  @relation("DoctorPatient_Doctor", fields: [doctorId], references: [id], onDelete: Cascade)
  patient   PatientProfile @relation("DoctorPatient_Patient", fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([doctorId, patientId])
  @@index([patientId])
  @@index([doctorId])
  @@map("DoctorPatient")
  @@schema("public")
}

model SelectedPharmacy {
  id         String          @id @default(uuid())
  patientId  String
  pharmacyId String
  preferred  Boolean         @default(false)
  createdAt  DateTime        @default(now())
  patient    PatientProfile  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  pharmacy   PharmacyProfile @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@unique([patientId, pharmacyId])
  @@map("SelectedPharmacy")
  @@schema("public")
}

model SystemSetting {
  id          Int      @id @default(1)
  systemName  String?
  themeColor  String?
  logoUrl     String?
  defaultFee  Float?
  monthlyPlan Float?
  yearlyPlan  Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("SystemSetting")
  @@schema("public")
}

model Medicine {
  id                   String              @id @default(uuid())
  pharmacyId           String
  name                 String
  genericName          String?
  category             String
  manufacturer         String?
  description          String?
  stockQuantity        Int                 @default(0)
  unitPrice            Float
  currency             String              @default("USD")
  dosageForm           String?
  strength             String?
  packSize             Int?
  isAvailable          Boolean             @default(true)
  requiresPrescription Boolean             @default(true)
  lowStockThreshold    Int                 @default(10)
  imageUrl             String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  pharmacy             PharmacyProfile     @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  orderItems           MedicineOrderItem[]

  @@index([pharmacyId])
  @@index([name])
  @@map("medicine")
  @@schema("public")
}

model MedicineOrder {
  id                String              @id @default(uuid())
  orderNumber       String              @unique
  patientId         String
  pharmacyId        String
  prescriptionId    String?
  status            OrderStatus         @default(PENDING)
  subtotal          Float
  deliveryFee       Float               @default(0)
  tax               Float               @default(0)
  discount          Float               @default(0)
  totalAmount       Float
  paymentStatus     String              @default("PENDING")
  paymentMethod     String?
  paymentReference  String?             @unique
  deliveryAddress   String?
  deliveryType      String              @default("PICKUP")
  estimatedDelivery DateTime?
  notes             String?
  rejectionReason   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  completedAt       DateTime?
  patient           PatientProfile      @relation(fields: [patientId], references: [id])
  pharmacy          PharmacyProfile     @relation(fields: [pharmacyId], references: [id])
  prescription      Prescription?       @relation(fields: [prescriptionId], references: [id])
  items             MedicineOrderItem[]
  transactions      Transaction[]

  @@index([patientId])
  @@index([pharmacyId])
  @@index([status])
  @@index([orderNumber])
  @@map("medicineorder")
  @@schema("public")
}

model MedicineOrderItem {
  id         String        @id @default(uuid())
  orderId    String
  medicineId String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  medicine   Medicine      @relation(fields: [medicineId], references: [id])
  order      MedicineOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([medicineId])
  @@map("medicineorderitem")
  @@schema("public")
}

model Transaction {
  id                 String            @id @default(uuid())
  userId             String
  type               TransactionType
  status             TransactionStatus @default(PENDING)
  amount             Float
  currency           String            @default("USD")
  provider           String
  providerTxId       String?           @unique
  providerCustomerId String?
  subscriptionId     String?
  orderId            String?
  description        String?
  metadata           String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  appointmentId      String?
  appointment        Appointment?      @relation(fields: [appointmentId], references: [id])
  order              MedicineOrder?    @relation(fields: [orderId], references: [id])
  subscription       Subscription?     @relation(fields: [subscriptionId], references: [id])
  user               User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("transaction")
  @@schema("public")
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  type       NotificationType
  title      String
  message    String
  link       String?
  actionData String?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notification")
  @@schema("public")
}

model VideoSession {
  id             String            @id @default(uuid())
  consultationId String            @unique
  channelName    String            @unique
  token          String?
  uid            String?
  startedAt      DateTime?
  endedAt        DateTime?
  duration       Int?
  recordingUrl   String?
  recordingId    String?
  consultation   VideoConsultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@map("videosession")
  @@schema("public")
}

model SystemMetric {
  id         String   @id @default(uuid())
  metricType String
  value      Float
  metadata   String?
  recordedAt DateTime @default(now())

  @@index([metricType, recordedAt])
  @@map("systemmetric")
  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_log_entries {
  instance_id String?   @db.Uuid
  id          String    @id @db.Uuid
  payload     Json?     @db.Json
  created_at  DateTime? @db.Timestamptz(6)
  ip_address  String    @default("") @db.VarChar(64)

  @@index([instance_id], map: "audit_logs_instance_id_idx")
  @@schema("auth")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model custom_oauth_providers {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_type         String
  identifier            String    @unique
  name                  String
  client_id             String
  client_secret         String
  acceptable_client_ids String[]  @default([])
  scopes                String[]  @default([])
  pkce_enabled          Boolean   @default(true)
  attribute_mapping     Json      @default("{}")
  authorization_params  Json      @default("{}")
  enabled               Boolean   @default(true)
  email_optional        Boolean   @default(false)
  issuer                String?
  discovery_url         String?
  skip_nonce_check      Boolean   @default(false)
  cached_discovery      Json?
  discovery_cached_at   DateTime? @db.Timestamptz(6)
  authorization_url     String?
  token_url             String?
  userinfo_url          String?
  jwks_uri              String?
  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime  @default(now()) @db.Timestamptz(6)

  @@index([created_at])
  @@index([enabled])
  @@index([identifier])
  @@index([provider_type])
  @@schema("auth")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
